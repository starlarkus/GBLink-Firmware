#include <zephyr/dt-bindings/pinctrl/rpi-pico-rp2040-pinctrl.h>

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
    };
};

&pio0 {
    status = "okay";

    pio_link: piolink {
        compatible = "raspberrypi,pico_link";
        status = "okay";
        pio = <&pio0>;
        pinctrl-0 = <&pio0_pin_default>;
        pinctrl-names = "default";
    };
};

&pio1 {
    status = "okay";
};

&pinctrl {
    pio0_pin_default: pio0_pin_default {
        link_pins {
            pinmux = <PIO0_P0>, <PIO0_P1>, <PIO0_P2>, <PIO0_P3>;
            bias-pull-up;
            input-enable;
        };
    };
};

/*
 * Carve a 4 KB storage partition (one flash erase sector) off the top of flash
 * for persistent settings (URL toggle and LED customization). The application is
 * less than 200 KB and lives at the bottom, so the tail is free. The UF2 only writes
 * the app region, so this sector survives firmware updates.
 */
&code_partition {
    reg = <0x100 (DT_SIZE_M(2) - 0x100 - DT_SIZE_K(4))>;
};

&flash0 {
    partitions {
        storage_partition: partition@1ff000 {
            label = "storage";
            reg = <0x001ff000 DT_SIZE_K(4)>;
        };
    };
};
